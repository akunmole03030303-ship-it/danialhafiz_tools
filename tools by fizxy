PLACE_ID="97598239454123"

# DETEKSI OTOMATIS SEMUA PACKAGE YANG BERAWALAN com.roblox
APPS=$(pm list packages | grep "com.roblox" | cut -d ":" -f2)

if [ -z "$APPS" ]; then
    echo "[!] Error: Tidak ada aplikasi Roblox (com.roblox*) yang terdeteksi!"
    exit 1
fi

CFG="/data/data/com.termux/files/home/roblox_config"

# TIMER CACHE
LAST_CC=$(date +"%H:%M:%S")
EXPIRE=$(($(date +%s) + 1800))

# MENU PILIHAN METODE JOIN
clear
echo "======================================================="
echo "       ROBLOX MULTI-INSTANCE AUTO JOINER"
echo "======================================================="
echo " Silakan pilih metode join:"
echo " -> Ketik 'public' untuk masuk ke server publik"
echo " -> Tempel/Paste link VIP untuk masuk private server"
echo "======================================================="
echo -n "[?] Masukkan pilihan kalian: "
read USER_INPUT

if [ -z "$USER_INPUT" ]; then
    echo "[!] Input tidak boleh kosong!"
    exit 1
fi

if [ "$USER_INPUT" = "public" ]; then
    LINK="roblox://experiences/start?placeId=$PLACE_ID"
    echo "[+] Mode Terpilih: PUBLIC SERVER"
elif echo "$USER_INPUT" | grep -q "roblox.com/games/"; then
    LINK="$USER_INPUT"
    echo "[+] Mode Terpilih: PRIVATE SERVER"
else
    echo "[!] Input tidak valid!"
    exit 1
fi

sleep 2

panel() {
    clear
    local RAM=$(free -m | awk '/Mem:/ { print $3 "/" $2 "MB" }')
    local JAM=$(date +"%H:%M:%S")
    
    echo -e "\e[1;36mв”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\e[0m"
    echo -e "\e[1;32m             [ ROBLOX MANAGER BY FIZXY ]            \e[0m"
    echo -e "\e[1;36mв”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө\e[0m"
    echo -e "\e[1;33m > RAM DEVICE      : $RAM\e[0m"
    echo -e "\e[1;33m > LAST CLEAN      : $LAST_CC\e[0m"
    echo -e "\e[1;33m > TIME            : $JAM\e[0m"
    echo -e "\e[1;36mв”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө\e[0m"
    echo -e "\e[1;37m   PACKAGE NAME               |       STATUS        \e[0m"
    echo -e "\e[1;36mв”ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Ө\e[0m"
    
    for PKG in $APPS; do
        if pm list packages | grep -q "$PKG"; then
            local PID=$(pidof $PKG)
            if [ -z "$PID" ]; then
                STATUS="\e[1;31mOFFLINE\e[0m"
            else
                STATUS="\e[1;32mONLINE \e[0m"
            fi
            printf "   \e[1;37m%-26s\e[0m |       %b\n" "$PKG" "$STATUS"
        fi
    done
    echo -e "\e[1;36mв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ\e[0m"
}

# AUTO REFRESH CACHE
cc_auto() {
    local SKRG=$(date +%s)
    if [ $SKRG -ge $EXPIRE ]; then
        echo -e "\e[1;34m[*] Cleaning cache system...\e[0m"
        for PKG in $APPS; do
            [ -d "/data/data/$PKG/cache" ] && rm -rf /data/data/$PKG/cache/* 2>/dev/null
        done
        LAST_CC=$(date +"%H:%M:%S")
        EXPIRE=$(($SKRG + 1800))
        sleep 1
    fi
}

# KILL SISA PROSES
for PKG in $APPS; do 
    pm list packages | grep -q "$PKG" && am force-stop $PKG 2>/dev/null
done

# MAIN LOOP
while :; do
    cc_auto
    
    for PKG in $APPS; do
        if pm list packages | grep -q "$PKG"; then
            PID=$(pidof $PKG)

            if [ -z "$PID" ]; then
                echo -e "\e[1;31m[!] $PKG dead. Restarting...\e[0m"
                
                # INJECT CONFIG
                mkdir -p /data/data/$PKG/shared_prefs/
                if [ -f "$CFG/${PKG}_config.xml" ]; then
                    cp -f "$CFG/${PKG}_config.xml" "/data/data/$PKG/shared_prefs/com.roblox.client.xml"
                    chmod 444 "/data/data/$PKG/shared_prefs/com.roblox.client.xml"
                fi
                
                # JALANKAN ROBLOX (Menyesuaikan link yang dipilih di awal)
                am start --user 0 -a android.intent.action.VIEW -d "$LINK" "$PKG" > /dev/null 2>&1
                
                # OOM ADJUST (ANTI-KILL)
                sleep 10
                NPID=$(pidof $PKG)
                [ -n "$NPID" ] && echo "-1000" > /proc/$NPID/oom_score_adj 2>/dev/null
                
                sleep 50
            fi
        fi
    done
    
    panel
    sleep 20
done
